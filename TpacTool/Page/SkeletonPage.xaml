<?xml version="1.0" encoding="utf-8"?>
<Page x:Class="TpacTool.SkeletonPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:local="clr-namespace:TpacTool"
      xmlns:TpacTool="clr-namespace:TpacTool"
      xmlns:loc="clr-namespace:TpacTool.Properties"
      Title="{x:Static loc:Resources.Skeleton_Page_Title}"
      Width="600"
      DataContext="{Binding Path=Skeleton, Source={StaticResource Locator}}">
    <Page.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
    </Page.Resources>
    <Grid>
        <Panel.Background>
            <SolidColorBrush Color="{DynamicResource {x:Static SystemColors.ControlColorKey}}" />
        </Panel.Background>
        <StackPanel Orientation="Horizontal">
            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalAlignment="Left" MaxWidth="220">
                <StackPanel Margin="5">
                    <Expander Header="{x:Static loc:Resources.Skeleton_Properties}" Margin="0,0,0,5" IsExpanded="True">
                        <StackPanel Margin="0,5,0,0">
                            <Expander Header="{x:Static loc:Resources.Skeleton_Info}" Margin="5,0,5,5" IsExpanded="True" BorderBrush="{DynamicResource {x:Static SystemColors.ActiveBorderBrushKey}}">
                                <StackPanel Margin="0,0,4,0">
                                    <Grid Margin="0,2">
                                        <Label Content="{x:Static loc:Resources.Skeleton_Name}" FontSize="11" />
                                        <TextBox IsReadOnly="True" Height="20" Margin="55,0,0,0" VerticalAlignment="Center" Text="{Binding SelectedSkeleton.Name, Mode=OneWay}" />
                                    </Grid>
                                    <Grid Margin="0,2">
                                        <Label Content="{x:Static loc:Resources.Skeleton_Type}" FontSize="11" />
                                        <TextBox IsReadOnly="True" Height="20" Margin="55,0,0,0" VerticalAlignment="Center" Text="{Binding SelectedSkeleton.Type, Mode=OneWay}" />
                                    </Grid>
                                    <Grid Margin="0,2">
                                        <Label Content="{x:Static loc:Resources.Skeleton_BoundingBoxMin}" FontSize="11" />
                                        <TextBox IsReadOnly="True" Height="20" Margin="90,0,0,0" VerticalAlignment="Center" Text="{Binding SelectedSkeleton.UserData.Data.BoundingBoxMin, Mode=OneWay}" />
                                    </Grid>
                                    <Grid Margin="0,2">
                                        <Label Content="{x:Static loc:Resources.Skeleton_BoundingBoxMax}" FontSize="11" />
                                        <TextBox IsReadOnly="True" Height="20" Margin="90,0,0,0" VerticalAlignment="Center" Text="{Binding SelectedSkeleton.UserData.Data.BoundingBoxMax, Mode=OneWay}" />
                                    </Grid>
                                    <Grid Margin="0,2">
                                        <Label Content="{x:Static loc:Resources.Skeleton_BoundingBoxPadding}" FontSize="11" />
                                        <TextBox IsReadOnly="True" Height="20" Margin="100,0,0,0" VerticalAlignment="Center" Text="{Binding SelectedSkeleton.UserData.Data.BoundingBoxPadding, Mode=OneWay}" />
                                    </Grid>
                                </StackPanel>
                            </Expander>
                        </StackPanel>
                    </Expander>
                    <Expander Header="{x:Static loc:Resources.Skeleton_SubItems}" Margin="0,0,0,5" IsExpanded="True">
                        <StackPanel Margin="0,5,0,0">
                            <Button Height="26" Margin="5,2" Content="{x:Static loc:Resources.Skeleton_ShowBoneBody}" Command="{Binding SelectBonesPageCommand, Mode=OneWay}" />
                            <Button Height="26" Margin="5,2" Content="{x:Static loc:Resources.Skeleton_ShowD6Joint}" Command="{Binding SelectD6JointsPageCommand, Mode=OneWay}" />
                            <Button Height="26" Margin="5,2" Content="{x:Static loc:Resources.Skeleton_ShowIKJoint}" Command="{Binding SelectIKJointsPageCommand, Mode=OneWay}" />
                        </StackPanel>
                    </Expander>
                    <Expander Header="{x:Static loc:Resources.Skeleton_Operations}" Margin="0,0,0,5" IsExpanded="True">
                        <StackPanel Margin="0,5,0,0">
                            <Button Height="26" Margin="5,2" Content="{x:Static loc:Resources.Skeleton_CopyProperties}" Command="{Binding CopyPropertiesCommand, Mode=OneWay}" />
                            <Button Height="26" Margin="5,2" Content="{x:Static loc:Resources.Skeleton_PasteProperties}" Command="{Binding PastePropertiesCommand, Mode=OneWay}" IsEnabled="{Binding CanPasteProperties, Mode=OneWay}" />
                            <Grid Margin="5,2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Button Height="26" Grid.Column="0" Margin="0,0,2,0" Content="{x:Static loc:Resources.Skeleton_SaveTPAC}" Command="{Binding SaveTPACCommand, Mode=OneWay}" />
                                <Button Height="26" Grid.Column="1" Margin="2,0,0,0" Content="{x:Static loc:Resources.Skeleton_SaveTPACAs}" Command="{Binding SaveTPACAsCommand, Mode=OneWay}" />
                            </Grid>
                            <Button Height="26" Margin="5,2" Content="{x:Static loc:Resources.Skeleton_ExportSingleAsset}" Command="{Binding ExportSingleAssetCommand, Mode=OneWay}" Visibility="{Binding ShowExportButton, Converter={StaticResource BoolToVisibilityConverter}, Mode=OneWay}" />
                        </StackPanel>
                    </Expander>
                </StackPanel>
            </ScrollViewer>
            <Frame MinWidth="350" Source="{Binding CurrentPageUri, Mode=OneWay}" />
        </StackPanel>
    </Grid>
</Page>