<?xml version="1.0" encoding="utf-8"?>
<Page x:Class="TpacTool.SkeletonCollisionPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:local="clr-namespace:TpacTool"
      xmlns:loc="clr-namespace:TpacTool.Properties"
      Title="{x:Static loc:Resources.SkeletonCollision_Page_Title}"
      Width="400"
      DataContext="{Binding Path=Skeleton, Source={StaticResource Locator}}">
    <Grid Margin="5">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <TextBlock Grid.Row="0" Text="{x:Static loc:Resources.SkeletonCollision_List}" FontWeight="Bold" Margin="0,0,0,5"/>
        
        <ListBox Grid.Row="1" ItemsSource="{Binding SkeletonBones}" SelectedItem="{Binding SelectedBone}" MinHeight="200">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <StackPanel Orientation="Horizontal" Margin="2">
                        <TextBlock Text="{Binding BoneName}" Width="150"/>
                        <TextBlock Text="R:" Foreground="Gray"/>
                        <TextBlock Text="{Binding CollisionRadius, StringFormat=F2}" Width="50"/>
                        <TextBlock Text="MR:" Foreground="Gray"/>
                        <TextBlock Text="{Binding CollisionMaxRadius, StringFormat=F2}"/>
                    </StackPanel>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
        
        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,5,0,0">
            <Button Content="{x:Static loc:Resources.SkeletonCollision_Add}" Height="26" Margin="0,0,5,0" Command="{Binding AddBoneBodyCommand}"/>
            <Button Content="{x:Static loc:Resources.SkeletonCollision_Remove}" Height="26" Command="{Binding RemoveBoneBodyCommand}"/>
        </StackPanel>
    </Grid>
</Page>