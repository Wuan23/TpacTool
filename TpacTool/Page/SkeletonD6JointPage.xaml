<?xml version="1.0" encoding="utf-8"?>
<Page x:Class="TpacTool.SkeletonD6JointPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:local="clr-namespace:TpacTool"
      Title="SkeletonD6Joint"
      DataContext="{Binding Path=Skeleton, Source={StaticResource Locator}}">
    <Grid>
        <Panel.Background>
            <SolidColorBrush Color="{DynamicResource {x:Static SystemColors.ControlColorKey}}" />
        </Panel.Background>
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <Label>D6 Joints</Label>
                <Grid Margin="5,0,5,5">
                    <ComboBox Text="Select A Joint" DisplayMemberPath="Name" ItemsSource="{Binding Path=SkeletonD6Joints, Mode=OneWay}" SelectedItem="{Binding SelectedD6Joint, Mode=TwoWay}" />
                </Grid>
                <Grid>
                    <Label Content="Name" />
                    <TextBox IsReadOnly="False" Height="22" Margin="85,2,0,2" VerticalAlignment="Center" Text="{Binding SelectedD6Joint.Name, Mode=TwoWay}" />
                </Grid>
                <Grid>
                    <Label Content="Bone1" />
                    <TextBox IsReadOnly="False" Height="22" Margin="85,2,0,2" VerticalAlignment="Center" Text="{Binding SelectedD6Joint.Bone1, Mode=TwoWay}" />
                </Grid>
                <Grid>
                    <Label Content="Bone2" />
                    <TextBox IsReadOnly="False" Height="22" Margin="85,2,0,2" VerticalAlignment="Center" Text="{Binding SelectedD6Joint.Bone2, Mode=TwoWay}" />
                </Grid>
                <Grid>
                    <Label Content="Position" />
                    <TextBox IsReadOnly="True" Height="22" Margin="85,2,0,2" VerticalAlignment="Center" Text="{Binding SelectedD6Joint.Position, Mode=OneWay}" />
                </Grid>
                <Grid>
                    <Label Content="Entity Space&#xD;&#xA; Rotation" />
                    <TextBox IsReadOnly="True" Height="22" Margin="85,2,0,2" VerticalAlignment="Center" Text="{Binding SelectedD6Joint.EntitySpaceRotation, Mode=OneWay}" />
                </Grid>
                <Grid>
                    <Label Content="Axis Limit" />
                    <TextBox IsReadOnly="True" Height="22" Margin="85,0,0,0" VerticalAlignment="Center" Text="{Binding SelectedD6Joint.AxisLimit, Mode=OneWay}" />
                </Grid>
                <Grid>
                    <Label Content="Axis Lock X" />
                    <TextBox IsReadOnly="True" Height="22" Margin="85,0,0,0" VerticalAlignment="Center" Text="{Binding SelectedD6Joint.AxisLockX, Mode=OneWay}" />
                </Grid>
                <Grid>
                    <Label Content="Axis Lock Y" />
                    <TextBox IsReadOnly="True" Height="22" Margin="85,0,0,0" VerticalAlignment="Center" Text="{Binding SelectedD6Joint.AxisLockY, Mode=OneWay}" />
                </Grid>
                <Grid>
                    <Label Content="Axis Lock Z" />
                    <TextBox IsReadOnly="True" Height="22" Margin="85,0,0,0" VerticalAlignment="Center" Text="{Binding SelectedD6Joint.AxisLockZ, Mode=OneWay}" />
                </Grid>
                <Grid>
                    <Label Content="Twist&#xD;&#xA;Upper Limit" />
                    <TextBox IsReadOnly="True" Height="22" Margin="85,0,0,0" VerticalAlignment="Center" Text="{Binding SelectedD6Joint.TwistUpperLimit, Mode=OneWay}" />
                </Grid>
                <Grid>
                    <Label Content="Twist&#xD;&#xA;Lower Limit" />
                    <TextBox IsReadOnly="True" Height="22" Margin="85,0,0,0" VerticalAlignment="Center" Text="{Binding SelectedD6Joint.TwistLowerLimit, Mode=OneWay}" />
                </Grid>
                <Grid>
                    <Label Content="Twist Lock" />
                    <TextBox IsReadOnly="True" Height="22" Margin="85,0,0,0" VerticalAlignment="Center" Text="{Binding SelectedD6Joint.TwistLock, Mode=OneWay}" />
                </Grid>
                <Grid>
                    <Label Content="Swing 1 Lock" />
                    <TextBox IsReadOnly="True" Height="22" Margin="85,0,0,0" VerticalAlignment="Center" Text="{Binding SelectedD6Joint.Swing1Lock, Mode=OneWay}" />
                </Grid>
                <Grid>
                    <Label Content="Swing 1 Limit" />
                    <TextBox IsReadOnly="True" Height="22" Margin="85,0,0,0" VerticalAlignment="Center" Text="{Binding SelectedD6Joint.Swing1Limit, Mode=OneWay}" />
                </Grid>
                <Grid>
                    <Label Content="Swing 2 Limit" />
                    <TextBox IsReadOnly="True" Height="22" Margin="85,0,0,0" VerticalAlignment="Center" Text="{Binding SelectedD6Joint.Swing2Limit, Mode=OneWay}" />
                </Grid>
                <Grid>
                    <Label Content="Swing 2 Lock" />
                    <TextBox IsReadOnly="True" Height="22" Margin="85,0,0,0" VerticalAlignment="Center" Text="{Binding SelectedD6Joint.Swing2Lock, Mode=OneWay}" />
                </Grid>
                <Grid Margin="0,0,0,10">
                    <Button VerticalAlignment="Top" Height="24" Margin="10,10,10,0" Content="Remove D6 Joint" IsEnabled="True" Command="{Binding RemoveD6JointCommand, Mode=OneWay}" />
                </Grid>
                <Grid Margin="0,0,0,10">
                    <Button VerticalAlignment="Top" Height="24" Margin="10,10,10,0" Content="Add D6 Joint" IsEnabled="True" Command="{Binding AddD6JointCommand, Mode=OneWay}" />
                </Grid>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>